{
  "slot": 1,
  "multi_set_enabled": true,
  "detail_level": "FULL",
  "access_scopes": ["monitor", "operate", "configure", "administer"],
  "default_scope": "operate",
  "params": {
    "analysis": {
      "type": "INT32",
      "value": { "int32_value": 0 },
      "name": { "display_strings": { "en": "Analyzer Mode" } },
      "constraint": {
        "type": "INT_CHOICE",
        "int32_choice": {
          "choices": [
            { "value": 0, "name": { "display_strings": { "en": "Stream ST 2110-20" } } },
            { "value": 1, "name": { "display_strings": { "en": "Stream ST 2110-22 (JPEG-XS)" } } },
            { "value": 2, "name": { "display_strings": { "en": "Difference between streams" } } }
          ]
        }
      },
      "widget": "radio",
      "access_scope": "operate"
    },
    "amplification": {
      "type": "FLOAT32",
      "value": { "float32_value": 1.0 },
      "name": { "display_strings": { "en": "Difference amplification" } },
      "widget": "default",
      "access_scope": "operate",
      "constraint": {
        "type": "FLOAT_RANGE",
        "float_range": {
          "min_value": 0.0,
          "max_value": 20.0,
          "step": 0.1
        }
      },
      "precision": 2
    },
    "product": {
        "type": "STRING",
        "value": { "string_value": "Catena + MCM Demo" },
        "name": { "display_strings": { "en": "Product" } },
        "read_only": true,
        "access_scope": "monitor"
    },
    "partners": {
        "type": "STRING_ARRAY",
        "value": {
            "string_array_values": {
                "strings": ["Ross Video", "Intel", "Cisco"]
            }
        },
        "name": { "display_strings": { "en": "Partners" } },
        "read_only": true,
        "access_scope": "monitor"
    },
    "a_number": {
      "type": "INT32",
      "name": {
        "display_strings": {
          "en": "A Number"
        }
      },
      "value": {
        "int32_value": 42
      },
      "stateless": true
    }
  },
  "menu_groups": {
    "status": {
      "name": { "display_strings": { "en": "Status" } },
      "menus": {
        "status": {
          "name": { "display_strings": { "en": "Product" } },
          "param_oids": ["/product", "/partners"]
        }
      }
    },
    "config": {
      "name": { "display_strings": { "en": "Config" } },
      "menus": {
        "config": {
          "name": { "display_strings": { "en": "Analyzer" } },
          "param_oids": ["/analysis","/amplification"]
        }
      }
    }
  }
