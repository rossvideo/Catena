{
  "name": "Go Catena Development Container",
  "build": {
    "dockerfile": "devcontainer.dockerfile",
    "context": ".",
    "args": {
      "USER_UID": "1000", //export UID=$(id -u)
      "USER_GID": "1000", //export GID=$(id -g)
      "USER_NAME": "${localEnv:USER}",
      "IMAGE_TITLE": "Catena Development Go Container",
      "IMAGE_DESCRIPTION": "Go development container for Catena",
      "IMAGE_VERSION": "1.0.1",
      "IMAGE_VENDOR": "Ross Video",
      "BUILD_TYPE": "Debug",
      "CONNECTIONS": "REST",
      "BUILD_TARGET": "~/Catena/build/go"
    }
  },
  "postCreateCommand": {
    "dockerInit": "sudo groupdel docker || true && DOCKER_GID=$(stat -c '%g' /var/run/docker.sock) && sudo groupadd -forg $DOCKER_GID docker && sudo usermod -aG docker ${USER_NAME}",
    "goEnvScript": "~/Catena/.devcontainer/go/postCreateCommand.sh ${USER_NAME} ${BUILD_TARGET} ~/Catena"
  },
  "runArgs": [
    "--env-file",
    "./.devcontainer/go/devcontainer.env"
  ],
  "forwardPorts": [
    6254,
    8000,
    8080,
    443
  ],
  "remoteUser": "${localEnv:USER}",
  "workspaceFolder": "/home/${localEnv:USER}/Catena",
  "containerEnv": {
    // image does not contain locales package, restrict to C locale
    // otherwise the host locale settings may cause issues
    "LANG": "C.UTF-8"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "/bin/bash"
          }
        },
        "[go]": {
          "editor.formatOnSave": true
        },
        "go.formatTool": "gofmt"
      },
      "extensions": [
        "redhat.vscode-yaml",
        "mhutchie.git-graph",
        "github.vscode-pull-request-github",
        "golang.go",
        "ryanluker.vscode-coverage-gutters"
      ]
    }
  },
  "mounts": [
    // Mount the build directory as a volume first so that it doesn't sync back to the host
    "source=catena-build-go,target=/home/${localEnv:USER}/Catena/build/go,type=volume",
    // Then, mount the Catena directory so that we can sync other changes back to the host
    "source=/home/${localEnv:USER}/Catena,target=/home/${localEnv:USER}/Catena,type=bind",
    // the docker daemon
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ]
}
