<?xml version="1.0" encoding="UTF-8"?><abs contexttype="opengear" id="_top" keepalive="false" style="bg#tablezebra;">
   <meta>
      <api id="controller" immediate="true" name="Controller" src="small_knob_controller.grid.js"/>

      <params>
         <param access="1" constraint="20.0;20000.0;20.0;20000.0" constrainttype="FLOAT_RANGE" name="" oid="freq" precision="0" type="FLOAT32" value="10706.589" widget="text"/>
      </params>
      <widgets>
         <widgetdescriptor id="small_knob">
            <config>
               <params>
                  <param access="1" constraint="0;16383;1;" constrainttype="INT_STEP_RANGE" oid="idx" type="INT16" value="0" widget="wheel"/>
               </params>
            </config>
            <oglml>
               <simplegrid rows="3">
                  <param height="30" oid="idx" width="30">
                    <task tasktype="onchange">  
                       ctrl.event('wheel', this);
                    </task>
                  </param>
                  <label height="15" name="Freq" style="txt-align:center;font:bold;" width="60"/>
                  <param height="20" oid="freq" value="20" width="60">
                     <config key="w.style">background-color: #333333; color: white; font:bold; border-radius: 8px; border: 2px solid #666666; text-align: center;</config>
                  </param>
               </simplegrid>
            </oglml>
         </widgetdescriptor>
      </widgets>
   </meta>




   <!-- Channel Grid -->
   <simplegrid cols="8" height="720" hspace="10" left="20" rows="1" top="206" width="1510">
      <!-- Channel 1 -->
      <abs height="720" left="25" name="Channel 1" style="bg#panelbg;bdr#buttonbg;bdr:round;look:round;" top="50" width="180">
         <!-- Channel Label -->
         <label header="true" height="20" left="30" name="Channel 1" style="txt-align:center;bdr#lightdivider;bdr:round;" top="20" width="120"/>
         <!-- Solo and Select buttons -->
         <table height="74" left="10" maxperrow="1" top="55" width="160">
            <tr>
               <button buttontype="toggle" colspan="1" fill="both" insets="2,2,2,2" name="SOLO" rowspan="1" style="bdr#darkdivider;bdr:round;t:bg#yellow;f:bg#readonlyborder;" weightx="1.0" weighty="1.0"/>
            </tr>
            <tr>
               <button buttontype="toggle" colspan="1" fill="both" insets="2,2,2,2" name="SELECT" rowspan="1" style="bdr#darkdivider;bdr:round;t:bg#timerfg;f:bg#readonlyborder;" weightx="1.0" weighty="1.0"/>
            </tr>
         </table>
         <!-- Bottom Button Panel - Centered with individual tables -->
         <abs height="160" left="10" style="m:5,5,5,5;" top="540" width="160">
            <!-- Top Row: Off and Reset -->
            <table height="35" left="0" top="0" width="160">
               <tr>
                  <button buttontype="toggle" colspan="1" fill="both" height="35" insets="2,2,2,2" name="On/Off" rowspan="1" style="bdr#darkdivider;bdr:round;t:bg#yellow;f:bg#red;" weightx="1.0" weighty="1.0" width="45"/>
