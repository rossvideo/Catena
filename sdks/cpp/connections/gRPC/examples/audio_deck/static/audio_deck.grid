                  <button buttontype="toggle" colspan="1" fill="both" insets="2,2,2,2" name="Eq" rowspan="1" style="bdr#darkdivider;bdr:round;t:bg#yellow;f:bg#readonlyborder;" weightx="1.0" weighty="1.0"/>
